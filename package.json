{
  "name": "@qntx/tsconfig",
  "version": "1.0.1",
  "description": "Shared TSConfig configs for qntx projects",
  "keywords": [
    "qntx",
    "tsconfig",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qntx/tsconfig.git"
  },
  "files": [
    "configs"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "bun install --cwd example && bun run --cwd example check",
    "test": "bun run check",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "latest",
    "typescript": "^5.9.3"
  }
}
